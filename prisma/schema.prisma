generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model posts {
  posterAddress           String
  postContentID           String
  allPostsCounter         BigInt
  userPostsCounter        BigInt
  postBlockHeight         BigInt
  deletionBlockHeight     BigInt
  restorationBlockHeight  BigInt
  postSignature           String
  toBeDeletedBlockHeight  BigInt?
  toBeDeletedSignature    String?
  toBeRestoredBlockHeight BigInt?
  toBeRestoredSignature   String?

  @@id([posterAddress, postContentID])
}
